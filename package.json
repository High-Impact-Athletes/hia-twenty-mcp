    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "agents": "^0.4.0",
    "@cloudflare/workers-oauth-provider": "^0.2.2",
