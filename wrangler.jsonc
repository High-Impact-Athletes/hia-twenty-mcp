{
  "name": "hia-twenty-mcp",
  // "account_id": "<YOUR_CLOUDFLARE_ACCOUNT_ID>",  // or set CLOUDFLARE_ACCOUNT_ID env var
  "main": "src/index.ts",
  "compatibility_date": "2025-04-01",
  "compatibility_flags": ["nodejs_compat"],
  "rules": [
    { "type": "Text", "globs": ["**/*.md"], "fallthrough": true }
  ],
  // TWENTY_BASE_URL is set via `wrangler secret` or the deploy button secrets prompt.
  // Do not duplicate it as a plaintext var here.
  "durable_objects": {
    "bindings": [
      {
        "name": "MCP_OBJECT",
        "class_name": "TwentyMCP"
      }
    ]
  },
  "kv_namespaces": [
    {
      "binding": "OAUTH_KV",
      "id": "<OAUTH_KV_ID>"  // create with: wrangler kv namespace create twenty-mcp-oauth
    }
  ],
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["TwentyMCP"]
    }
  ]
}
